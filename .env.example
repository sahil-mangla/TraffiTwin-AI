# TraffiTwin AI — Local Development Environment Variables
# ===========================================================
# This file is for LOCAL DEVELOPMENT ONLY. Copy to `.env` and fill in values.
#
# Production deployments must NOT use a .env file. Secrets are injected by the
# hosting platform instead:
#   - Backend (Hugging Face Spaces): set via the Space's "Repository secrets"
#     UI, which are exposed to the container as environment variables.
#   - CI/CD (GitHub Actions): set via repo Settings -> Secrets and variables,
#     referenced in .github/workflows/ci.yml as ${{ secrets.* }}.
# See docs/SECRETS.md for the full policy.

# Environment discriminator: "development" | "test" | "production"
# Controls stricter validation in backend/config.py (e.g. production requires
# ALLOWED_ORIGINS to be explicitly set rather than falling back to localhost).
ENVIRONMENT=development

# Directory containing the raw METR-LA dataset files.
DATA_DIR=datasets/raw

# Path to the trained LightGBM reconstruction model checkpoint.
MODEL_PATH=backend/models/checkpoints/lightgbm_baseline.pkl

# Google Gemini API key, used to enrich incident summaries with natural-
# language reports. Optional — if unset, the app falls back to deterministic
# rule-based summaries (see backend/services/rule_based_reporter.py).
GEMINI_API_KEY="your-api-key-here"

# Comma-separated list of allowed CORS origins.
# Add your Firebase Hosting URLs here for production.
# Example:
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://traffitwin-ai.web.app,https://traffitwin-ai.firebaseapp.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
